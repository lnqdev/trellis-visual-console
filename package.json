{
  "name": "trellis-visual-console",
  "version": "0.2.0-beta.5",
  "private": true,
  "type": "module",
  "description": "面向个人本机使用的 Trellis 只读可视化内容中心",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tauri build",
    "build:mac:arm64": "tauri build --target aarch64-apple-darwin --bundles app,dmg",
    "build:mac:x64": "tauri build --target x86_64-apple-darwin --bundles app,dmg",
    "build:windows:x64": "tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "build:web": "vite build",
    "check:version": "node scripts/check-version-consistency.mjs",
    "check:update-manifest": "node scripts/validate-update-manifest.mjs",
    "release:prepare": "node scripts/prepare-release.mjs",
    "release:ci": "node scripts/release-ci.mjs",
    "release:mac": "node scripts/release-macos.mjs",
    "release:mac:prepare": "node scripts/release-macos.mjs prepare",
    "release:mac:stage": "node scripts/release-macos.mjs stage",
    "release:mac:upload": "node scripts/release-macos.mjs upload",
    "release:mac:publish": "node scripts/release-macos.mjs publish-manifest",
    "check:rust": "cargo check --workspace --all-targets --all-features",
    "tauri": "tauri",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
