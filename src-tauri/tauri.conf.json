{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trellis Visual Console",
  "version": "0.2.0-beta.8",
  "identifier": "com.wanglinqiao.trellis-visual-console",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://127.0.0.1:5273",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Trellis Visual Console",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwRDJFMDhERkI1QjBGNEIKUldSTEQxdjdqZURTRUxzT0d5bm8zdXd1SG96VVk3NmFEVFpqL3RBNGM1K0RDZlFoMXVKMU05bEsK",
      "endpoints": [
        "https://gitee.com/wanglinqiao/trellis-visual-console/raw/main/releases/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "SimpChinese"
        ],
        "displayLanguageSelector": false,
        "installerHooks": "windows/nsis-hooks.nsh"
      }
    }
  }
}
